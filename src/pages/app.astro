---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Bobdock App"
	description="Connect GitHub, choose a repository, and generate a browsable documentation site."
>
	<main class="min-h-screen brand-shell">
		<div class="mx-auto flex min-h-screen max-w-7xl flex-col px-5 py-6 lg:px-8">
			<div class="navbar brand-nav px-3">
				<div class="navbar-start">
					<a href="/" class="btn btn-ghost gap-3 px-2 text-xl font-semibold tracking-normal">
						<span class="brand-mark">BD</span>
						Bobdock
					</a>
				</div>
				<div class="navbar-end gap-2">
					<button id="reset-github" class="btn btn-ghost btn-sm hidden" type="button">Reset GitHub</button>
					<div class="badge badge-primary badge-soft hidden sm:inline-flex">App</div>
				</div>
			</div>

			<section id="credentials-section" class="grid flex-1 items-center gap-10 py-16 lg:grid-cols-[0.92fr_1.08fr]">
				<div class="max-w-2xl">
					<div class="rail-label mb-5">GitHub setup</div>
					<h1 class="text-4xl font-bold leading-tight tracking-normal md:text-6xl">
						Connect GitHub to generate repository documentation.
					</h1>
					<p class="mt-5 text-lg leading-8 text-base-content/70">
						Add your GitHub details, choose a repository, and Bobdock will create the
						documentation site used for browsing and agent context.
					</p>
					<div class="mt-8 grid gap-3 sm:grid-cols-3">
						{['Repository access', 'Generated docs', 'Agent context'].map((item) => (
							<div class="rounded-box dock-tile p-4 text-sm font-medium">
								{item}
							</div>
						))}
					</div>
				</div>

				<div class="card dock-panel">
					<form id="credentials-form" class="card-body gap-5 p-6 md:p-8">
						<div>
							<h2 class="card-title text-2xl">GitHub credentials</h2>
							<p class="mt-2 text-sm leading-6 text-base-content/65">
								Use a personal access token with the repository permissions your workspace needs.
							</p>
						</div>

						<label class="form-control w-full">
							<div class="label">
								<span class="label-text font-medium">GitHub username</span>
							</div>
							<input
								id="github-username"
								class="input input-bordered w-full"
								placeholder="octocat"
								autocomplete="username"
								required
							/>
						</label>

						<label class="form-control w-full">
							<div class="label">
								<span class="label-text font-medium">Personal access token</span>
							</div>
							<input
								id="github-token"
								class="input input-bordered w-full font-mono"
								placeholder="github_pat_..."
								type="password"
								autocomplete="off"
								required
							/>
						</label>

						<div class="alert border-base-300 bg-base-100/90">
							<svg class="h-6 w-6 stroke-info" fill="none" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11v4m0-8h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
							</svg>
							<span class="text-sm">Use a token with the repository access Bobdock should work with.</span>
						</div>

						<div class="card-actions mt-2">
							<button class="btn btn-primary btn-block" type="submit">Save and enter</button>
						</div>
					</form>
				</div>
			</section>

			<div id="existing-docs-modal" class="modal" data-open="false">
				<div class="modal-box max-w-lg">
					<h3 class="text-lg font-bold">Documentation already exists</h3>
					<p class="py-4">This repository already has documentation generated by Bobdock. What would you like to do?</p>
					
					<div class="form-control py-4">
						<label class="label cursor-pointer justify-start gap-3">
							<input id="read-existing-docs-checkbox" type="checkbox" class="checkbox checkbox-primary" />
							<span class="label-text flex items-center gap-2">
								<span class="font-medium">Read existing documentation</span>
								<div class="tooltip tooltip-top" data-tip="When enabled, Bob will analyze existing .bobdock documentation and enhance it. Otherwise, it will ignore .bob* folders and regenerate from code only.">
									<svg class="h-4 w-4 text-base-content/50 cursor-help" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
								</div>
							</span>
						</label>
					</div>
	
					<div class="modal-action">
						<button id="open-existing-btn" class="btn btn-primary">Open existing documentation</button>
						<button id="regenerate-btn" class="btn btn-secondary">Regenerate documentation</button>
					</div>
				</div>
				<div class="modal-backdrop bg-black/50"></div>
			</div>
	
			<div id="folder-selection-modal" class="modal" data-open="false">
				<div class="modal-box max-w-2xl max-h-[80vh]">
					<h3 class="text-lg font-bold">Select items to exclude</h3>
					<p class="py-2 text-sm text-base-content/70">Uncheck folders and files you want to exclude from documentation. Everything checked will be analyzed by Bob.</p>
					
					<div id="folder-loading" class="flex items-center justify-center py-8">
						<span class="loading loading-spinner loading-md text-primary"></span>
						<span class="ml-3 text-sm">Loading repository structure...</span>
					</div>
	
					<div id="folder-error" class="alert alert-error hidden my-4">
						<svg class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"></path>
						</svg>
						<span id="folder-error-message" class="text-sm">Failed to load repository structure.</span>
					</div>
	
					<div id="folder-list" class="hidden max-h-96 overflow-y-auto border border-base-300 rounded-lg p-4 my-4">
						<div class="form-control">
							<label class="label cursor-pointer justify-start gap-3 py-2">
								<input id="select-all-items" type="checkbox" class="checkbox checkbox-sm checkbox-primary" checked />
								<span class="label-text font-semibold">Include all items</span>
							</label>
						</div>
						<div class="divider my-1"></div>
						<div id="item-checkboxes" class="space-y-1"></div>
					</div>
	
					<div class="modal-action">
						<button id="cancel-folder-selection-btn" class="btn btn-ghost">Cancel</button>
						<button id="confirm-folder-selection-btn" class="btn btn-primary">Continue</button>
					</div>
				</div>
				<div class="modal-backdrop bg-black/50"></div>
			</div>

			<section id="repo-section" class="hidden flex-1 items-center gap-10 py-16 lg:grid lg:grid-cols-[0.9fr_1.1fr]">
				<div class="max-w-2xl">
					<div id="connected-badge" class="badge badge-success badge-soft mb-5">Connected</div>
					<h1 class="text-4xl font-bold leading-tight tracking-normal md:text-6xl">
						Choose the repository to document.
					</h1>
					<p class="mt-5 text-lg leading-8 text-base-content/70">
						Add a GitHub repository URL and Bobdock will generate a Starlight documentation
						site that can be browsed and attached as context to coding-agent tasks.
					</p>
				</div>

				<div class="card dock-panel">
					<form id="repo-form" class="card-body gap-5 p-6 md:p-8">
						<div>
							<h2 class="card-title text-2xl">Repository intake</h2>
							<p class="mt-2 text-sm leading-6 text-base-content/65">
								Paste the repository URL you want Bobdock to prepare.
							</p>
						</div>

						<label class="form-control w-full">
							<div class="label">
								<span class="label-text font-medium">GitHub repository URL</span>
							</div>
							<input
								id="repo-url"
								class="input input-bordered w-full"
								placeholder="https://github.com/acme/product"
								type="url"
								required
							/>
						</label>

						<div class="grid gap-3 sm:grid-cols-3">
							{['Repository', 'Docs site', 'Agent context'].map((item) => (
								<div class="rounded-box dock-tile p-4">
									<p class="text-sm text-base-content/55">Ready for</p>
									<p class="font-semibold">{item}</p>
								</div>
							))}
						</div>

						<div id="generation-loading" class="alert hidden border-base-300 bg-base-200">
							<span class="loading loading-spinner loading-sm text-primary"></span>
							<span id="generation-loading-message" class="text-sm">
								Bobdock is scanning the repository and generating documentation.
							</span>
						</div>

						<div id="generation-error" class="alert alert-error hidden">
							<svg class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"></path>
							</svg>
							<span id="generation-error-message" class="text-sm">Documentation generation failed.</span>
						</div>

						<div class="card-actions mt-2">
							<button id="generate-button" class="btn btn-primary btn-block" type="submit">Generate documentation</button>
						</div>
					</form>
				</div>
			</section>
		</div>
	</main>

	<script>
		const storageKeys = {
			username: 'bobdock.github.username',
			token: 'bobdock.github.token',
		};

		const credentialsSection = document.querySelector('#credentials-section');
		const repoSection = document.querySelector('#repo-section');
		const resetButton = document.querySelector('#reset-github');
		const credentialsForm = document.querySelector('#credentials-form');
		const repoForm = document.querySelector('#repo-form');
		const usernameInput = document.querySelector('#github-username');
		const tokenInput = document.querySelector('#github-token');
		const repoInput = document.querySelector('#repo-url');
		const connectedBadge = document.querySelector('#connected-badge');
		const loadingAlert = document.querySelector('#generation-loading');
		const loadingMessage = document.querySelector('#generation-loading-message');
		const errorAlert = document.querySelector('#generation-error');
		const errorMessage = document.querySelector('#generation-error-message');
		const generateButton = document.querySelector('#generate-button');
		const existingDocsModal = document.querySelector('#existing-docs-modal');
		const openExistingBtn = document.querySelector('#open-existing-btn');
		const regenerateBtn = document.querySelector('#regenerate-btn');
		const readExistingDocsCheckbox = document.querySelector('#read-existing-docs-checkbox');
		const folderSelectionModal = document.querySelector('#folder-selection-modal');
		const folderLoading = document.querySelector('#folder-loading');
		const folderError = document.querySelector('#folder-error');
		const folderErrorMessage = document.querySelector('#folder-error-message');
		const folderList = document.querySelector('#folder-list');
		const itemCheckboxes = document.querySelector('#item-checkboxes');
		const selectAllItems = document.querySelector('#select-all-items');
		const cancelFolderSelectionBtn = document.querySelector('#cancel-folder-selection-btn');
		const confirmFolderSelectionBtn = document.querySelector('#confirm-folder-selection-btn');
	
		let pendingRepoUrl = '';
		let pendingJobId = '';
		let pendingDocsUrl = '';
		let pendingReadExistingDocs = false;
		let excludedItems = [];

		function readValue(key) {
			try {
				return window.localStorage.getItem(key) || '';
			} catch {
				return '';
			}
		}

		function writeValue(key, value) {
			try {
				window.localStorage.setItem(key, value);
			} catch {
				// Keep the current in-memory form flow usable even if persistence is unavailable.
			}
		}

		function writeTokenCookie(token) {
			if (!token) return;
			document.cookie = `bobdock.github.token=${encodeURIComponent(token)}; Path=/; SameSite=Lax`;
		}

		function removeValue(key) {
			try {
				window.localStorage.removeItem(key);
			} catch {
				// No-op.
			}
		}

		function showRepoForm(username) {
			credentialsSection?.classList.add('hidden');
			repoSection?.classList.remove('hidden');
			repoSection?.classList.add('grid');
			resetButton?.classList.remove('hidden');
			if (connectedBadge) {
				connectedBadge.textContent = username ? `Connected as ${username}` : 'Connected';
			}
		}

		function showCredentialsForm() {
			repoSection?.classList.add('hidden');
			repoSection?.classList.remove('grid');
			credentialsSection?.classList.remove('hidden');
			resetButton?.classList.add('hidden');
		}

		function setLoading(isLoading, message = 'Bobdock is scanning the repository and generating documentation.') {
			loadingAlert?.classList.toggle('hidden', !isLoading);
			if (loadingMessage) loadingMessage.textContent = message;
			repoInput?.toggleAttribute('disabled', isLoading);
			generateButton?.toggleAttribute('disabled', isLoading);
			if (generateButton) {
				generateButton.textContent = isLoading ? 'Generating documentation...' : 'Generate documentation';
			}
		}

		function delay(ms) {
			return new Promise((resolve) => window.setTimeout(resolve, ms));
		}

		async function pollGenerationJob(jobId) {
			let pollCount = 0;
			let statusFailureCount = 0;

			for (;;) {
				await delay(pollCount < 20 ? 1000 : 5000);
				pollCount += 1;

				let response;
				let result;

				try {
					response = await fetch(`/api/generate-docs/status?jobId=${encodeURIComponent(jobId)}`);
					result = await response.json();
				} catch {
					statusFailureCount += 1;

					if (statusFailureCount >= 12) {
						throw new Error('Bobdock could not reach the status endpoint after several retries.');
					}

					setLoading(true, `Reconnecting to the status endpoint (${statusFailureCount}/12).`);
					continue;
				}

				statusFailureCount = 0;

				if (!response.ok || result.status === 'failed') {
					throw new Error(result.error || 'Bobdock could not generate documentation for this repository.');
				}

				const progressMessage = formatProgressMessage(result);
				if (progressMessage) {
					setLoading(true, progressMessage);
				}

				if (result.status === 'completed' && result.docsUrl) {
					return result;
				}
			}
		}

		function formatProgressMessage(result) {
			const outputTail = typeof result.outputTail === 'string' ? result.outputTail.trim() : '';
			const errorTail = typeof result.errorTail === 'string' ? result.errorTail.trim() : '';
			const source = outputTail || errorTail;

			if (!source) {
				return result.status === 'queued'
					? 'Bobdock has queued documentation generation.'
					: 'Bobdock is working on the repository.';
			}

			const lines = source
				.split(/\r?\n/)
				.map((line) => line.trim())
				.filter(Boolean);
			const lastUsefulLine = lines.at(-1);

			if (!lastUsefulLine) {
				return 'Bobdock is working on the repository.';
			}

			return lastUsefulLine.length > 240 ? `${lastUsefulLine.slice(0, 237)}...` : lastUsefulLine;
		}

		const savedUsername = readValue(storageKeys.username);
		const savedToken = readValue(storageKeys.token);

		if (savedUsername && savedToken) {
			showRepoForm(savedUsername);
		}

		credentialsForm?.addEventListener('submit', (event) => {
			event.preventDefault();
			const username = usernameInput instanceof HTMLInputElement ? usernameInput.value.trim() : '';
			const token = tokenInput instanceof HTMLInputElement ? tokenInput.value.trim() : '';

			if (!username || !token) return;

			writeValue(storageKeys.username, username);
			writeValue(storageKeys.token, token);
			writeTokenCookie(token);
			showRepoForm(username);
		});

		resetButton?.addEventListener('click', () => {
			removeValue(storageKeys.username);
			removeValue(storageKeys.token);
			document.cookie = 'bobdock.github.token=; Path=/; Max-Age=0; SameSite=Lax';
			if (usernameInput instanceof HTMLInputElement) usernameInput.value = '';
			if (tokenInput instanceof HTMLInputElement) tokenInput.value = '';
			if (repoInput instanceof HTMLInputElement) repoInput.value = '';
			showCredentialsForm();
		});

		repoForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const repoUrl = repoInput instanceof HTMLInputElement ? repoInput.value.trim() : '';
			const username = readValue(storageKeys.username);
			const token = readValue(storageKeys.token);

			if (!repoUrl) return;

			errorAlert?.classList.add('hidden');

			try {
				const checkResponse = await fetch('/api/check-existing-docs', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ repoUrl, githubToken: token }),
				});

				const checkResult = await checkResponse.json();

				if (checkResult.success && checkResult.exists && checkResult.docsUrl) {
					pendingRepoUrl = repoUrl;
					pendingDocsUrl = checkResult.docsUrl;
					pendingReadExistingDocs = false;
					existingDocsModal?.setAttribute('open', 'true');
					return;
				}
			} catch {
				// Check failed, proceed with folder selection
			}
	
			// Show folder selection modal
			pendingRepoUrl = repoUrl;
			pendingReadExistingDocs = false;
			await showFolderSelectionModal(repoUrl, token);
		});
	
		openExistingBtn?.addEventListener('click', () => {
			existingDocsModal?.removeAttribute('open');
			if (pendingDocsUrl) {
				const token = readValue(storageKeys.token);
				writeTokenCookie(token);
				window.location.assign(pendingDocsUrl);
			}
		});
	
		regenerateBtn?.addEventListener('click', async () => {
			existingDocsModal?.removeAttribute('open');
			const token = readValue(storageKeys.token);
			pendingReadExistingDocs = readExistingDocsCheckbox instanceof HTMLInputElement ? readExistingDocsCheckbox.checked : false;
			
			// Show folder selection modal
			await showFolderSelectionModal(pendingRepoUrl, token);
		});
	
		cancelFolderSelectionBtn?.addEventListener('click', () => {
			folderSelectionModal?.removeAttribute('open');
			excludedItems = [];
		});
	
		confirmFolderSelectionBtn?.addEventListener('click', () => {
			folderSelectionModal?.removeAttribute('open');
			const username = readValue(storageKeys.username);
			const token = readValue(storageKeys.token);
			startGeneration(pendingRepoUrl, username, token, pendingReadExistingDocs, excludedItems);
		});
	
		selectAllItems?.addEventListener('change', (event) => {
			const checked = event.target instanceof HTMLInputElement ? event.target.checked : false;
			const checkboxes = itemCheckboxes?.querySelectorAll('input[type="checkbox"]');
			checkboxes?.forEach((checkbox) => {
				if (checkbox instanceof HTMLInputElement) {
					checkbox.checked = checked;
				}
			});
			updateExcludedItems();
		});
	
		async function showFolderSelectionModal(repoUrl, token) {
			folderSelectionModal?.setAttribute('open', 'true');
			folderLoading?.classList.remove('hidden');
			folderError?.classList.add('hidden');
			folderList?.classList.add('hidden');
			if (itemCheckboxes) itemCheckboxes.innerHTML = '';
			excludedItems = [];
			
			try {
				const response = await fetch('/api/get-repo-structure', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ repoUrl, githubToken: token }),
				});
	
				const result = await response.json();
	
				if (!response.ok || !result.success) {
					throw new Error(result.error || 'Failed to load repository structure.');
				}
	
				folderLoading?.classList.add('hidden');
				folderList?.classList.remove('hidden');
				
				renderItemTree(result.structure);
				updateExcludedItems();
			} catch (error) {
				folderLoading?.classList.add('hidden');
				folderError?.classList.remove('hidden');
				if (folderErrorMessage) {
					folderErrorMessage.textContent = error instanceof Error ? error.message : 'Failed to load repository structure.';
				}
			}
		}
	
		function renderItemTree(structure) {
			if (!itemCheckboxes) return;
	
			const sortedItems = Object.keys(structure).sort();
			
			for (const itemName of sortedItems) {
				const item = structure[itemName];
				const isFolder = item.type === 'folder';
				const icon = isFolder ? '📁' : '📄';
				
				// Create parent item checkbox
				const parentDiv = document.createElement('div');
				parentDiv.className = 'form-control';
				
				const parentLabel = document.createElement('label');
				parentLabel.className = 'label cursor-pointer justify-start gap-3 py-1.5';
				
				const parentCheckbox = document.createElement('input');
				parentCheckbox.type = 'checkbox';
				parentCheckbox.className = 'checkbox checkbox-sm checkbox-primary';
				parentCheckbox.value = itemName;
				parentCheckbox.checked = true; // Default to included (checked)
				parentCheckbox.addEventListener('change', updateExcludedItems);
				
				const parentSpan = document.createElement('span');
				parentSpan.className = 'label-text font-medium';
				parentSpan.textContent = `${icon} ${itemName}`;
				
				parentLabel.appendChild(parentCheckbox);
				parentLabel.appendChild(parentSpan);
				parentDiv.appendChild(parentLabel);
				itemCheckboxes.appendChild(parentDiv);
				
				// Create child item checkboxes for folders
				if (isFolder && item.children.length > 0) {
					const childrenDiv = document.createElement('div');
					childrenDiv.className = 'ml-6 space-y-1';
					
					for (const child of item.children) {
						const childDiv = document.createElement('div');
						childDiv.className = 'form-control';
						
						const childLabel = document.createElement('label');
						childLabel.className = 'label cursor-pointer justify-start gap-3 py-1';
						
						const childCheckbox = document.createElement('input');
						childCheckbox.type = 'checkbox';
						childCheckbox.className = 'checkbox checkbox-sm checkbox-secondary';
						childCheckbox.value = `${itemName}/${child}`;
						childCheckbox.checked = true; // Default to included (checked)
						childCheckbox.addEventListener('change', updateExcludedItems);
						
						const childSpan = document.createElement('span');
						childSpan.className = 'label-text text-sm';
						childSpan.textContent = `📂 ${child}`;
						
						childLabel.appendChild(childCheckbox);
						childLabel.appendChild(childSpan);
						childDiv.appendChild(childLabel);
						childrenDiv.appendChild(childDiv);
					}
					
					itemCheckboxes.appendChild(childrenDiv);
				}
			}
		}
	
		function updateExcludedItems() {
			const allCheckboxes = itemCheckboxes?.querySelectorAll('input[type="checkbox"]');
			const uncheckedBoxes = Array.from(allCheckboxes || []).filter(
				cb => cb instanceof HTMLInputElement && !cb.checked
			);
			
			excludedItems = uncheckedBoxes
				.map((cb) => cb instanceof HTMLInputElement ? cb.value : '')
				.filter(Boolean);
			
			if (confirmFolderSelectionBtn) {
				const excludedCount = excludedItems.length;
				confirmFolderSelectionBtn.textContent = excludedCount > 0
					? `Continue (excluding ${excludedCount} item${excludedCount > 1 ? 's' : ''})`
					: 'Continue (all items included)';
			}
		}
	
		async function startGeneration(repoUrl, username, token, readExistingDocs = false, excludeItems = []) {
			setLoading(true, 'Starting Bobdock documentation generation.');
	
			try {
				const response = await fetch('/api/generate-docs', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						repoUrl,
						githubUsername: username,
						githubToken: token,
						readExistingDocs,
						excludeItems,
					}),
				});

				const result = await response.json();

				if (!response.ok || !result.success || !result.jobId) {
					throw new Error(result.error || 'Bobdock could not start documentation generation for this repository.');
				}

				const completedJob = await pollGenerationJob(result.jobId);
				writeTokenCookie(token);
				window.location.assign(completedJob.docsUrl);
			} catch (error) {
				const message = error instanceof Error ? error.message : 'Documentation generation failed.';
				if (errorMessage) errorMessage.textContent = message;
				errorAlert?.classList.remove('hidden');
				setLoading(false);
			}
		}
	</script>
</Layout>
